# Administrator bootstrap (used ONLY by `npm run seed:admin`)
# Never commit a real production .env file.
# These values are NOT bundled into the public player app.

ADMIN_EMAIL=linkadmin@admin.com
ADMIN_PASSWORD=123qwe123QWE

# Private admin URLs (not linked from the player app):
#   /admin/  |  /admin.html  |  /admin/login.html
ADMIN_PUBLIC_PATH=/admin/

# Player app URL (used in verification email links)
APP_URL=http://127.0.0.1:5173
API_PORT=3001

# SMTP (Gmail app password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=link
SMTP_FROM_EMAIL=your-gmail@gmail.com

# Optional: real Google / Microsoft OAuth (otherwise buttons open provider signup pages)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# API_PUBLIC_URL=http://127.0.0.1:5173
