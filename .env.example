# =============================================================================
# LOCAL development: copy this file to `.env` and fill in secrets.
#   cp .env.example .env
#
# RENDER.COM: do NOT upload a .env file to the repo.
# Render injects variables from Dashboard → Environment (or this Blueprint).
# Keys marked sync:false in render.yaml must be typed in the Dashboard.
# You can bulk-paste a local .env via “Add from .env” in the Environment tab.
# Docs: https://render.com/docs/configure-environment-variables
# =============================================================================

# Administrator bootstrap (used by `npm run seed:admin` / prebuild)
# Never commit a real production .env file.
# These values are NOT bundled into the public player app.

ADMIN_EMAIL=linkadmin@admin.com
ADMIN_PASSWORD=123qwe123QWE

# Private admin URLs (not linked from the player app):
#   /admin/  |  /admin.html  |  /admin/login.html
ADMIN_PUBLIC_PATH=/admin/

# Player app URL (used in verification email links / CORS)
# On Render, set this to your service URL, e.g. https://battlefield-link.onrender.com
APP_URL=http://127.0.0.1:5173
# Local API only. On Render: do NOT set HOST or API_PORT — Render injects PORT
# and the app always binds 0.0.0.0 there. Setting HOST=127.0.0.1 causes deploy timeouts.
API_PORT=3001
HOST=127.0.0.1

# Optional: absolute Windows download URL for the player app (defaults to same-origin /secret).
# Local test: leave unset (Vite proxies /secret → API :3001).
# Production override example:
# VITE_SECRET_DOWNLOAD_URL=https://battlefield-link.onrender.com/secret
# VITE_SECRET_DOWNLOAD_URL=

# Database: when DATABASE_URL is set the backend persists to PostgreSQL.
# Leave it blank locally to use JSON files under server/data/.
# On Render this is injected automatically from the linked database (see render.yaml).
# DATABASE_URL=postgres://user:pass@host:5432/link
# Set DATABASE_SSL=disable only for a local Postgres without TLS.
# DATABASE_SSL=

# SMTP is OPTIONAL now — registration no longer sends OTP email.
# Keep these only if you later re-enable transactional mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=link
SMTP_FROM_EMAIL=

# Optional: real Google / Microsoft OAuth (otherwise buttons open provider signup pages)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# API_PUBLIC_URL=http://127.0.0.1:5173
