{
  "name": "link",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "seed:admin": "node scripts/seed-admin.mjs",
    "seed:secret": "node scripts/seed-secret.mjs",
    "publish:secret": "node scripts/publish-secret.mjs",
    "gameapp:release": "node scripts/release-gameapp.mjs",
    "predev": "node scripts/ensure-env.mjs && node scripts/seed-admin.mjs",
    "prebuild": "node scripts/seed-admin.mjs",
    "dev:api": "node server/index.mjs",
    "dev:web": "vite",
    "dev": "concurrently -k -n api,web -c magenta,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "start:api": "node server/index.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "typescript": "~5.7.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "multer": "^2.2.0",
    "nodemailer": "^7.0.5",
    "pg": "^8.22.0",
    "ws": "^8.21.1"
  }
}
